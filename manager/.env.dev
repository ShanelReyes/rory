# --- Node Configuration ---
RORY_DEBUG=0
ENV_FILE_PATH=/rory/envs/.manager.env
NODE_ID=rory-manager-0
NODE_IP_ADDR=rory-manager-0
NODE_PORT=6000
SERVER_IP_ADDR=0.0.0.0

# --- Docker & Worker Configuration ---
NODE_PREFIX=rory-worker-
FOLDER_KEYS=keys128
INIT_WORKERS=0
WORKER_INIT_PORT=9000
DOCKER_IMAGE_NAME=rory
DOCKER_IMAGE_TAG=worker
DOCKER_NETWORK_ID=mictlanx
MAX_RETRIES=10
LOAD_BALANCING=0
WORKER_MAX_THREADS=2
WORKER_MEMORY=1000000000
WORKER_CPU=2
WORKER_TIMEOUT=300
SWARM_NODES=2,3,4,8

# --- Paths ---
SOURCE_PATH=/rory/source
SINK_PATH=/rory/sink
LOG_PATH=/rory/log

# --- Mictlanx Services ---
MICTLANX_SUMMONER_IP_ADDR=localhost
MICTLANX_SUMMONER_PORT=15000
MICTLANX_SUMMONER_MODE=docker
MICTLANX_API_VERSION=3
MICTLANX_URI=mictlanx://mictlanx-router-0@localhost:63666?api_version=4&protocol=http
MICTLANX_CLIENT_ID=CLIENT_ID
MICTLANX_TIMEOUT=120
MICTLANX_MAX_WORKERS=12
MICTLANX_DEBUG=0
MICTLANX_LOG_PATH=/rory/mictlanx
MICTLANX_LOG_INTERVAL=24
MICTLANX_LOG_WHEN=h
MICTLANX_PROTOCOL=https
MICTLANX_BUCKET_ID=rory
MICTLANX_DELAY=2
MICTLANX_BACKOFF_FACTOR=0.5
MICTLANX_MAX_RETRIES=10
MICTLANX_CHUNK_SIZE=256kb
MICTLANX_MAX_PARALELL_GETS=2

# --- Clustering & CKKS Parameters ---
LIU_ROUND=2
DISTANCE=MANHATHAN
MIN_ERROR=0.015
CKKS_ROUND=0
CKKS_DECIMALS=2
CTX_FILENAME=ctx
PUBKEY_FILENAME=pubkey
SECRET_KEY_FILENAME=secretkey
RELINKEY_FILENAME=relinkey