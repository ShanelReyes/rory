# --- Server & Node Configuration ---
NODE_ID=rory-worker-0
NODE_PORT=9000
NODE_INDEX=0
HOST_PORT=9000
NODE_IP_ADDR=rory-worker-0
SERVER_IP_ADDR=0.0.0.0
RELOAD=0
RORY_DEBUG=0

# --- Manager Configuration ---
RORY_MANAGER_PORT=6000
RORY_MANAGER_IP_ADDR=localhost
MAX_RETRIES=100

# --- Algorithm & CKKS Settings ---
DISTANCE=MANHATHAN
MIN_ERROR=0.015
CKKS_ROUND=0
CKKS_DECIMALS=2

# --- Paths & Storage ---
RORY_WORKER_ENV_FILE_PATH=.env
SOURCE_PATH=/rory/source
SINK_PATH=/rory/sink
LOG_PATH=/rory/log
KEYS_PATH=/rory/keys
CTX_FILENAME=ctx
PUBKEY_FILENAME=pubkey
SECRET_KEY_FILENAME=secretkey
RELINKEY_FILENAME=relinkey

# --- Mictlanx Configuration ---
MICTLANX_TIMEOUT=120
MICTLANX_CLIENT_ID=rory-worker-0_mictlanx
MICTLANX_API_VERSION=4
MICTLANX_PROTOCOL=http
MICTLANX_URI=mictlanx://mictlanx-router-0@localhost:63666?api_version=4&protocol=http
MICTLANX_DEBUG=0
MICTLANX_MAX_WORKERS=4
MICTLANX_LOG_PATH=/rory/mictlanx
MICTLANX_LOG_INTERVAL=24
MICTLANX_LOG_WHEN=h
MICTLANX_BUCKET_ID=rory
MICTLANX_DELAY=2
MICTLANX_BACKOFF_FACTOR=0.5
MICTLANX_MAX_RETRIES=10
MICTLANX_CHUNK_SIZE=256kb
MICTLANX_MAX_PARALELL_GETS=2